{
  "name": "personal-reports",
  "version": "1.0.3",
  "private": true,
  "description": "TypeScript scripts for GitHub Actions",
  "license": "GPL-3.0-only",
  "author": "7Koston",
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "clean": "node ./scripts/clean.ts dist",
    "clean:full": "node ./scripts/clean.ts dist node_modules pnpm-lock.yaml",
    "format": "prettier src/** --write",
    "lint": "eslint src/** && tsc --noEmit",
    "lint:fix": "eslint src/** --fix && tsc --noEmit",
    "local": "node --env-file=.env src/index.ts",
    "local:google:token": "node --env-file=.env scripts/google-refresh-token.ts"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dayjs": "^1.11.19",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^7.0.11",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "open": "^11.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.13.0"
  }
}
